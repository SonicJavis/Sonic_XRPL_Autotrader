# Canonical paper-runtime profile (Task 3)
# Hard safety defaults must remain fail-closed.

SONIC_RUNTIME_MODE=paper
SONIC_DRY_RUN=true
SONIC_STORAGE_PATH=/data/v2.db
SONIC_AUDIT_DIR=/opt/sonic/docs/audit
SONIC_RESEARCH_DIR=/opt/sonic/docs/research
SONIC_LOG_LEVEL=INFO

# Explicit safety invariants
EXECUTION_ENABLED=false
LIVE_TRADING_ENABLED=false

# Preserve app-compatible defaults if app env is loaded by tooling.
BOT_MODE=PAPER_TRADING
ALLOW_REMOTE_ACCESS=false
XRPL_INGESTION_ENABLED=false
