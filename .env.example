BOT_MODE=PAPER_TRADING
LIVE_TRADING_ENABLED=false
EXECUTION_ENABLED=false
ALLOW_REMOTE_ACCESS=false
ENV_MODE=LOCAL_DEV
DEBUG=false
API_AUTH_TOKEN=replace-with-long-random-token
ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
API_RATE_LIMIT_PER_MINUTE=120

XRPL_RPC_URL=https://s1.ripple.com:51234
XRPL_WS_URL=wss://s1.ripple.com
XRPL_INGESTION_ENABLED=false
XRPL_INGESTION_MODE=disabled
XRPL_SHADOW_SOURCE=static
XRPL_SNAPSHOT_THROTTLE_MS=500
XRPL_MAX_LEDGER_GAP=128
XRPL_MAX_SNAPSHOT_AGE_MS=15000
XRPL_WALLET_SEED=

MAX_TRADE_XRP=5
MAX_OPEN_POSITIONS=3
MAX_TOTAL_EXPOSURE_XRP=20
MAX_DAILY_LOSS_XRP=10
MIN_LIQUIDITY_XRP=1000
MAX_SPREAD_PCT=8
MAX_SLIPPAGE_PCT=5

DEFAULT_STOPLOSS_PCT=10
DEFAULT_TAKE_PROFIT_PCT=20

PAPER_STARTING_BALANCE_XRP=1000

DATABASE_URL=sqlite:///./sonic_autotrader.db
LOG_LEVEL=INFO
